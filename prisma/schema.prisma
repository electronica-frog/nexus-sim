// Multi-Agent Simulation System - NEXUS Adapted
// Persistent agents with memory, waves, and collaborative problem-solving

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== SESSION & PROJECT =====

model Project {
  id          String   @id @default(cuid())
  name        String
  description String
  status      String   @default("active") // active | completed | paused
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  waves      Wave[]
  agents     ProjectAgent[]
  memories   AgentMemory[]
  proposals  Proposal[]
  specs      Spec[]
  skills       AgentSkill[]
  memoryStore  MemoryStore[]
  logs         SystemLog[]
  prompts      Prompt[]
}

// ===== AGENTS (from The Agency) =====

model Agent {
  id          String   @id @default(cuid())
  agentId     String   @unique // e.g. "engineering-frontend-developer"
  name        String   // e.g. "Frontend Developer"
  division    String   // e.g. "engineering"
  emoji       String   @default("🤖")
  color       String   @default("cyan")
  vibe        String   @default("")
  personality String   // Full system prompt / personality definition
  tools       String   @default("")

  projectAgents ProjectAgent[]
}

// ===== PROJECT-AGENT ASSIGNMENT =====

model ProjectAgent {
  id          String   @id @default(cuid())
  projectId   String
  agentId     String

  role        String   @default("team") // orchestrator | team | qa | specialist
  status      String   @default("idle") // idle | thinking | done | failed
  waveNumber  Int      @default(0)
  trustScore  Float    @default(0.5) // 0-1 trust score based on wave participation

  project     Project  @relation(fields: [projectId], references: [id])
  agent       Agent    @relation(fields: [agentId], references: [id])

  responses   Response[]

  @@unique([projectId, agentId])
}

// ===== WAVES (Oleadas) =====

model Wave {
  id          String   @id @default(cuid())
  projectId   String
  number      Int
  type        String   // brainstorm | critique | synthesize | execute | quality_gate
  status      String   @default("pending") // pending | running | completed | failed
  prompt      String   // The problem/context given to agents
  result      String?  // Synthesized result of the wave
  specId      String?  // Optional link to a Spec

  // Wave identity — chosen by the agents themselves
  name        String   @default("")   // e.g. "Tormenta de Cristal" instead of "Wave #35"
  emoji       String   @default("")   // e.g. "🌩️" — chosen by participants
  personality String   @default("")   // collective personality traits of this wave

  project     Project  @relation(fields: [projectId], references: [id])
  spec        Spec?    @relation(fields: [specId], references: [id])
  responses   Response[]

  createdAt   DateTime @default(now())
  completedAt DateTime?

  @@unique([projectId, number])
}

// ===== AGENT RESPONSES =====

model Response {
  id          String   @id @default(cuid())
  waveId      String
  agentId     String   // FK to ProjectAgent

  content     String   // Agent's response/opinion
  confidence  Float    @default(0.5) // 0-1 how confident the agent is
  mood        String   @default("neutral") // enthusiastic | neutral | skeptical | concerned

  wave        Wave     @relation(fields: [waveId], references: [id])
  projectAgent ProjectAgent @relation(fields: [agentId], references: [id])

  createdAt   DateTime @default(now())
}

// ===== PERSISTENT MEMORY =====

model AgentMemory {
  id          String   @id @default(cuid())
  projectId   String
  agentId     String
  type        String   // fact | learning | preference | pattern
  content     String
  tags        String   @default("") // comma-separated tags
  importance  Float    @default(0.5) // 0-1
  embedding   Json?    // TF-IDF vector stored as JSON object

  project     Project  @relation(fields: [projectId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, agentId])
}

// ===== MEM0 MEMORY STORE (Long-term memory with decay) =====
// Inspired by Mem0: memories decay over time, consolidate, get relevance-scored.
// Each memory has a "score" that decays exponentially and is boosted by reuse.

model MemoryStore {
  id          String   @id @default(cuid())
  projectId   String
  agentId     String  // FK to Agent.id

  content     String  // Core memory content
  category    String  @default("general") // general | fact | skill | preference | pattern | insight | relationship
  tags        String  @default("") // comma-separated tags

  // Mem0 scoring: base score + decay + boosts
  baseScore   Float   @default(1.0)  // Initial importance (0-2)
  accessCount Int    @default(0)    // Times this memory was retrieved/used
  lastAccessedAt DateTime? // Last time it was used in context
  decayRate   Float   @default(0.05) // Exponential decay rate (0=no decay, 0.1=fast)

  // ChromaDB link for semantic search
  chromaId    String? // ID in the nexus-memory-store ChromaDB collection

  // Source tracking
  sourceWaveId  String? // Which wave created this memory
  sourceType    String  @default("wave") // wave | manual | consolidation | skill
  mergedFromIds String? // JSON array of IDs that were merged into this

  // Relevance (computed, not stored — but we cache it)
  cachedRelevance Float?
  relevanceUpdatedAt DateTime?

  project     Project  @relation(fields: [projectId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, agentId])
  @@index([projectId, category])
  @@index([agentId, sourceType])
}

// ===== AGENT SKILLS (Auto-Mejora / Self-Improvement) =====

model AgentSkill {
  id           String   @id @default(cuid())
  projectId    String
  agentId      String   // links to Agent.id (not ProjectAgent)
  name         String
  description  String
  sourceWaveId String?  // which wave generated this skill
  quality      Float    @default(0.5) // 0-1, improves with use
  timesUsed    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, agentId, name])
}

// ===== SPECIFICATIONS (Spec-Driven Development) =====

model Spec {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String
  phase       String   @default("draft")     // draft, design, implementation, review, completed
  priority    String   @default("medium")    // low, medium, high, critical
  status      String   @default("active")    // active, archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  waves       Wave[]
}

// ===== SYSTEM LOGS =====

model SystemLog {
  id        String   @id @default(cuid())
  projectId String
  type      String   // wave_created | wave_completed | skill_learned | spec_created | proposal_created | trust_change
  message   String
  metadata  String   @default("") // JSON string with extra details
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

// ===== PROPOSALS (from critique waves) =====

model Proposal {
  id          String   @id @default(cuid())
  projectId   String
  waveId      String?
  title       String
  description String
  type        String   // bugfix | enhancement | trend | idea | alert
  priority    String   @default("medium") // low | medium | high | urgent
  status      String   @default("proposed") // proposed | approved | rejected | implemented

  project     Project  @relation(fields: [projectId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ===== PROMPTS GALLERY =====

model Prompt {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  content     String
  authorAgent String?
  authorType  String   @default("human") // human | agent
  version     Int      @default(1)
  votes       Int      @default(0)
  tags        String   @default("")
  category    String   @default("general") // brainstorm | critique | synthesize | execute | quality_gate | general
  status      String   @default("active") // active | archived

  project     Project  @relation(fields: [projectId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, category])
  @@index([projectId, votes])
}
