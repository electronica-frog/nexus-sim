# ===== NEXUS Sim — Caddyfile (Docker Compose) =====
# This Caddyfile is used by the caddy service in docker-compose.yml.
# In Docker, Caddy communicates with the nexus service by container name.

:80 {
	# Reverse proxy to NEXUS Next.js app
	reverse_proxy nexus:3000 {
		header_up Host {host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote_host}

		# SSE support: long-lived connections for real-time updates
		flush_interval -1
	}
}

# Uncomment and set your domain for automatic HTTPS:
